# vim:ft=plumed
dih1: READ FILE=dih_w.dat VALUES=dih_r_N1C15C14N4 IGNORE_TIME
dih2: READ FILE=dih_w.dat VALUES=dih_r_N3C20C19N6 IGNORE_TIME

w: READ FILE=dih_w.dat VALUES=W IGNORE_TIME
lw: CUSTOM ARG=w FUNC=log(x) PERIODIC=NO 

h1: HISTOGRAM ARG=dih1 GRID_MIN=-pi GRID_MAX=pi GRID_BIN=100 LOGWEIGHTS=lw BANDWIDTH=0.02
f1: CONVERT_TO_FES GRID=h1 MINTOZERO
DUMPGRID GRID=f1 FILE=fes_dih1.dat

h2: HISTOGRAM ARG=dih2 GRID_MIN=-pi GRID_MAX=pi GRID_BIN=100 LOGWEIGHTS=lw BANDWIDTH=0.02
f2: CONVERT_TO_FES GRID=h2 MINTOZERO
DUMPGRID GRID=f2 FILE=fes_dih2.dat

h12: HISTOGRAM ARG=dih1,dih2 GRID_MIN=-pi,-pi GRID_MAX=pi,pi GRID_BIN=100,100 LOGWEIGHTS=lw BANDWIDTH=0.02,0.02
f12: CONVERT_TO_FES GRID=h12 MINTOZERO
DUMPGRID GRID=f12 FILE=fes_dih1dih2.dat


